rules_version = '2';

// All Firestore reads/writes go through the backend Admin SDK, which
// bypasses these rules. These rules block any direct client-side access.
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny all direct client-side access — backend Admin SDK is used exclusively
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
